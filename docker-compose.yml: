services:
  db:
    image: postgres:16
    environment:
      POSTGRES_DB: tn_jobs_db
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: password
    ports: ["5432:5432"]
  app:
    build: ./backend
    ports: ["8080:8080"]
    depends_on: [db]
  frontend:
    build: ./frontend
    ports: ["3000:3000"]
